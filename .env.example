META_ACCESS_TOKEN=your_meta_token_here
META_API_VERSION=v21.0

# Auth
AUTH_EMAIL=croman@santarosa.com.py
# Base64-encoded bcrypt hash (avoids dollar-sign expansion in .env).
# Generate: node -e "console.log(Buffer.from(require('bcryptjs').hashSync('YOUR_PASSWORD',10)).toString('base64'))"
AUTH_PASSWORD_HASH_B64=JDJiJDEwJHB3dWpiVjM5UVljTUoxYUs1ZllxSXU2VVZKMVZ0TFdwbGNoVXZGWlpZTUsyRVFZVERmVHU2
AUTH_SECRET=change_me_to_random_64_chars_min_for_jwt_signing_security_pls

# Postgres (Vercel Postgres add-on injects these automatically in prod)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# Cron secret (Vercel cron auth, generate 32+ chars random)
CRON_SECRET=

# Budget cap default
BUDGET_CAP_USD=1000

# TikTok Ads (set after TikTok app approval)
TIKTOK_APP_ID=
TIKTOK_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=

# Google Ads (set after MCC + Developer Token approval)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_REFRESH_TOKEN=
